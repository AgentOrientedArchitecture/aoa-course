# Copy this file to `.env` and fill in the values for your provider.
# `docker compose --env-file .env ...` reads this file from the repo root.

# ----------------------------------------------------------------------
# Model provider
# ----------------------------------------------------------------------
# One of: openai, anthropic, ollama.
#
# The course is designed for smaller, swappable models. Use Ollama for local
# open-weight models, or use PROVIDER=openai with OPENAI_BASE_URL for a hosted
# OpenAI-compatible endpoint.
PROVIDER=openai

# The model name as the provider knows it.
#   ollama    examples: gpt-oss:120b, qwen3:32b, qwen2.5:14b
#   openai    examples: gpt-oss-120b, qwen3-32b, gpt-4o-mini
#   anthropic examples: claude-3-5-sonnet-latest, claude-3-5-haiku-latest
MODEL=openai/gpt-oss-120b

# ----------------------------------------------------------------------
# Provider credentials
# ----------------------------------------------------------------------
# Only the variable matching your PROVIDER above needs to be set.

# Course key used inside containers. This avoids accidentally inheriting a
# global OPENAI_API_KEY from your shell when using an OpenAI-compatible provider.
AOA_OPENAI_API_KEY=

# Optional for direct local tests outside Docker. Compose does not use this
# value for containers; set AOA_OPENAI_API_KEY for the course stack.
OPENAI_API_KEY=

# Optional. Set this when PROVIDER=openai but your model is served by an
# OpenAI-compatible provider rather than api.openai.com.
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------
# Local model server (optional)
# ----------------------------------------------------------------------
# Used only when PROVIDER=ollama. Defaults to the optional Ollama container
# started with the `local` Compose profile. If you want to point at an Ollama
# you're already running on the host, change this to e.g.
# http://host.docker.internal:11434
OLLAMA_HOST=http://ollama:11434

# ----------------------------------------------------------------------
# Timeouts
# ----------------------------------------------------------------------
# Smaller local models can be slower, especially when parsing PDFs.
MODEL_TIMEOUT_SECONDS=240
MODEL_MAX_TOKENS=8192
OPENAI_REASONING_EFFORT=low
OPENAI_RESPONSE_FORMAT=json_object
OLLAMA_RESPONSE_FORMAT=json
OLLAMA_THINK=false
PLANNER_INVOKE_TIMEOUT=300
PLANNER_REQUEST_TIMEOUT=420
PLANNER_STRATEGY=hybrid
PLANNER_MODEL_TIMEOUT_SECONDS=60
PLANNER_MODEL_MAX_TOKENS=2048

# ----------------------------------------------------------------------
# Registry governance demo actors
# ----------------------------------------------------------------------
# These are seeded actor identities for the course registry lifecycle surface.
# They make publish/approve/review ownership visible without adding a full
# workflow engine.
REGISTRY_PUBLISHER_AGENT_ID=urn:aoa:role:platform-team-publisher
REGISTRY_APPROVER_AGENT_ID=urn:aoa:role:risk-curator-approver
REGISTRY_REVIEWER_AGENT_ID=urn:aoa:role:registry-reviewer
REGISTRY_DEFAULT_LIFECYCLE_STATUS=approved
