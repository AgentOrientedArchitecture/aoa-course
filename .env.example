# Copy this file to `.env` and fill in the values for your provider.
# `docker compose` reads `.env` from the directory it's invoked from, so
# `make up` (run from the repo root) will pick it up automatically.

# ----------------------------------------------------------------------
# Model provider
# ----------------------------------------------------------------------
# One of: openai, anthropic, ollama
PROVIDER=openai

# The model name as the provider knows it.
#   openai    examples: gpt-4o-mini, gpt-4o
#   anthropic examples: claude-3-5-sonnet-latest, claude-3-5-haiku-latest
#   ollama    examples: llama3.1, qwen2.5:14b
MODEL=gpt-4o-mini

# ----------------------------------------------------------------------
# Provider credentials
# ----------------------------------------------------------------------
# Only the variable matching your PROVIDER above needs to be set.

OPENAI_API_KEY=

ANTHROPIC_API_KEY=

# ----------------------------------------------------------------------
# Local model server (optional)
# ----------------------------------------------------------------------
# Used only when PROVIDER=ollama. Defaults to the Ollama container brought
# up by `make local-up`. If you want to point at an Ollama you're already
# running on the host, change this to e.g. http://host.docker.internal:11434
OLLAMA_HOST=http://ollama:11434
